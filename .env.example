# AegisFlow Backend — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Ensure .env is listed in .gitignore (it already is).

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# A secret key used to authenticate all API requests.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AEGISFLOW_API_KEY=

# ── Local Inference (Ollama) ──────────────────────────────────────────────────
# Ollama runs locally at port 11434 by default.
# Install: https://ollama.com | Pull model: ollama pull qwen3:0.6b
# Leave blank to use cloud-only routing.
OLLAMA_BASE_URL=http://localhost:11434

# ── Cloud Inference — Groq (FREE tier, recommended) ──────────────────────────
# Sign up: https://console.groq.com → API Keys → Create
GROQ_API_KEY=

# ── Cloud Inference — Gemini Flash (fallback) ────────────────────────────────
# Sign up: https://aistudio.google.com/apikey → Create API Key
GEMINI_API_KEY=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Required only if send_enterprise_email tool is used.
# Gmail: enable 2FA → App Passwords → generate a 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set DEBUG=true ONLY in local development. Never in production.
# Enables: /docs, /redoc, /api/v1/openapi.json, proposed_tool_override
DEBUG=false

# Set to true to enable the proposed_tool_override field for local testing.
# MUST be false in production.
ENABLE_DEBUG_OVERRIDES=false

# ── Token Budget Cap (server-side, optional) ──────────────────────────────────
# Maximum token budget any single request can request.
# Prevents cost exhaustion from crafted token_budget_override values.
MAX_TOKEN_BUDGET_OVERRIDE=100000
